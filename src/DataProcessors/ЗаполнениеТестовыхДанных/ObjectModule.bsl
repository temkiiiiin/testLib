// Ищет элемент справочника по наименованию, возвращает ссылку или Неопределено
//
// Параметры:
//   ИмяСправочника - Строка - имя метаданного справочника
//   Наименование   - Строка - искомое наименование
//
// Возвращаемое значение:
//   СправочникСсылка - найденная ссылка или Неопределено
Функция НайтиВСправочнике(ИмяСправочника, Наименование)

	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	Сп.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник." + ИмяСправочника + " КАК Сп
	|ГДЕ
	|	Сп.Наименование = &Наименование
	|	И НЕ Сп.ПометкаУдаления";
	Запрос.УстановитьПараметр("Наименование", Наименование);
	Рез = Запрос.Выполнить().Выгрузить();

	Если Рез.Количество() > 0 Тогда
		Возврат Рез[0].Ссылка;
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

#КонецОбласти
