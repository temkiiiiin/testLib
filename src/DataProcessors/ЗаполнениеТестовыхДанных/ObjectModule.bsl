// @strict-types

#Область ПрограммныйИнтерфейс

// Заполняет все тестовые данные и возвращает отчёт
//
// Возвращаемое значение:
//   Строка - краткий отчёт о заполнении
Функция ЗаполнитьВсе() Экспорт

	Лог = Новый Массив;

	// Справочники — порядок важен: сначала родительские
	ЗаполнитьКатегорииЧитателей(Лог);
	ЗаполнитьЖанры(Лог);
	ЗаполнитьАвторов(Лог);
	ЗаполнитьИздательства(Лог);
	ЗаполнитьМестаХранения(Лог);
	ЗаполнитьКниги(Лог);
	ЗаполнитьСотрудников(Лог);
	ЗаполнитьЧитателей(Лог);

	// Документы
	ЗаполнитьПоступленияКниг(Лог);
	ЗаполнитьВыдачиКниг(Лог);

	Возврат СтрСоединить(Лог, Символы.ПС);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// ---------- Справочники ----------

Процедура ЗаполнитьКатегорииЧитателей(Лог)

	Данные = Новый Массив;

	ЭлДанные = Новый Структура("Наименование, МаксКнигНаРуках, МаксСрокДней");
	ЭлДанные.Наименование      = "Школьник";
	ЭлДанные.МаксКнигНаРуках   = 3;
	ЭлДанные.МаксСрокДней      = 14;
	Данные.Добавить(ЭлДанные);

	ЭлДанные = Новый Структура("Наименование, МаксКнигНаРуках, МаксСрокДней");
	ЭлДанные.Наименование      = "Студент";
	ЭлДанные.МаксКнигНаРуках   = 5;
	ЭлДанные.МаксСрокДней      = 30;
	Данные.Добавить(ЭлДанные);

	ЭлДанные = Новый Структура("Наименование, МаксКнигНаРуках, МаксСрокДней");
	ЭлДанные.Наименование      = "Взрослый";
	ЭлДанные.МаксКнигНаРуках   = 10;
	ЭлДанные.МаксСрокДней      = 30;
	Данные.Добавить(ЭлДанные);

	Счётчик = 0;
	Для Каждого Эл Из Данные Цикл
		Если НайтиВСправочнике("КатегорииЧитателей", Эл.Наименование) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Объект = Справочники.КатегорииЧитателей.СоздатьЭлемент();
		Объект.Наименование      = Эл.Наименование;
		Объект.МаксКнигНаРуках   = Эл.МаксКнигНаРуках;
		Объект.МаксСрокДней      = Эл.МаксСрокДней;
		Объект.Записать();
		Счётчик = Счётчик + 1;
	КонецЦикла;

	Лог.Добавить("КатегорииЧитателей: добавлено " + Счётчик + " из " + Данные.Количество());

КонецПроцедуры

Процедура ЗаполнитьЖанры(Лог)

	Наименования = СтрРазделить("Роман,Детектив,Фантастика,Поэзия,Научная литература,Исторический роман,Приключения,Детская литература", ",");
	Счётчик = 0;

	Для Каждого Назв Из Наименования Цикл
		Если НайтиВСправочнике("Жанры", Назв) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Объект = Справочники.Жанры.СоздатьЭлемент();
		Объект.Наименование = Назв;
		Объект.Записать();
		Счётчик = Счётчик + 1;
	КонецЦикла;

	Лог.Добавить("Жанры: добавлено " + Счётчик + " из " + Наименования.Количество());

КонецПроцедуры

