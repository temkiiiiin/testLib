Функция СоздатьДокументПоступления(Дата, МестоХранения, МассивКниг, ПрефКод)

	Если МестоХранения = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Документ = Документы.ПоступлениеКниг.СоздатьДокумент();
	Документ.Дата          = Дата;
	Документ.МестоХранения = МестоХранения;

	НомерКниги = 1;
	Для Каждого НазвКниги Из МассивКниг Цикл
		КнигаСсылка = НайтиВСправочнике("Книги", НазвКниги);
		Если КнигаСсылка = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		// Добавляем 3 экземпляра каждой книги
		Для НомЭкз = 1 По 3 Цикл
			Строка = Документ.Книги.Добавить();
			Строка.Книга         = КнигаСсылка;
			Строка.КодЭкземпляра = ПрефКод + "-" + Формат(НомерКниги, "ЧЦ=2; ЧВН=; ЧГ=0") + "-" + НомЭкз;
			Строка.Количество    = 1;
			Строка.Цена          = 500;
			Строка.Состояние     = "Хорошее";
		КонецЦикла;
		НомерКниги = НомерКниги + 1;
	КонецЦикла;

	Документ.Записать(РежимЗаписиДокумента.Проведение);
	Возврат 1;

КонецФункции

