// @strict-types

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	// Движения по регистрам накопления
	Движения.КнигиНаРуках.Записывать    = Истина;
	Движения.ШтрафыЧитателей.Записывать = Истина;

	Для Каждого Строка Из Книги Цикл

		Движение = Движения.КнигиНаРуках.Добавить();
		Движение.ВидДвижения   = ВидДвиженияНакопления.Расход;
		Движение.Период        = Дата;
		Движение.Читатель      = Читатель;
		Движение.Книга         = Строка.Книга;
		Движение.КодЭкземпляра = Строка.КодЭкземпляра;
		Движение.Количество    = 1;

		Если Строка.Штраф > 0 Тогда
			ДвижШтраф = Движения.ШтрафыЧитателей.Добавить();
			ДвижШтраф.ВидДвижения = ВидДвиженияНакопления.Приход;
			ДвижШтраф.Период      = Дата;
			ДвижШтраф.Читатель    = Читатель;
			ДвижШтраф.Сумма       = Строка.Штраф;
		КонецЕсли;

	КонецЦикла;

	// Прямая запись факта возврата в регистр сведений ИсторияВыдач
	Для Каждого Строка Из Книги Цикл

		ЗапросИст = Новый Запрос;
		ЗапросИст.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИсторияВыдач.ДатаВыдачи КАК ДатаВыдачи
		|ИЗ
		|	РегистрСведений.ИсторияВыдач КАК ИсторияВыдач
		|ГДЕ
		|	ИсторияВыдач.Читатель      = &Читатель
		|	И ИсторияВыдач.КодЭкземпляра = &КодЭкземпляра
		|	И ИсторияВыдач.ФактДатаВозврата = ДАТАВРЕМЯ(1, 1, 1)
		|УПОРЯДОЧИТЬ ПО ИсторияВыдач.ДатаВыдачи УБЫВ";
		ЗапросИст.УстановитьПараметр("Читатель",      Читатель);
		ЗапросИст.УстановитьПараметр("КодЭкземпляра", Строка.КодЭкземпляра);
		РезИст = ЗапросИст.Выполнить().Выгрузить();

		Если РезИст.Количество() > 0 Тогда

			НаборЗаписей = РегистрыСведений.ИсторияВыдач.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Читатель.Установить(Читатель);
			НаборЗаписей.Отбор.КодЭкземпляра.Установить(Строка.КодЭкземпляра);
			НаборЗаписей.Отбор.ДатаВыдачи.Установить(РезИст[0].ДатаВыдачи);
			НаборЗаписей.Прочитать();

			Если НаборЗаписей.Количество() > 0 Тогда
				НаборЗаписей[0].ФактДатаВозврата = Дата;
				НаборЗаписей.Записать();
			КонецЕсли;

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)

	Движения.КнигиНаРуках.Записывать    = Истина;
	Движения.ШтрафыЧитателей.Записывать = Истина;

КонецПроцедуры

#КонецОбласти
