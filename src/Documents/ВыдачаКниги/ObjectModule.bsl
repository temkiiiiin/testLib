// @strict-types

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	КатЧитателя = Читатель.Категория;
	МаксКниг    = КатЧитателя.МаксКнигНаРуках;

	Если МаксКниг > 0 Тогда

		ЗапросЛимит = Новый Запрос;
		ЗапросЛимит.Текст =
		"ВЫБРАТЬ
		|	СУММА(КнигиНаРуках.КоличествоОстаток) КАК КоличествоНаРуках
		|ИЗ
		|	РегистрНакопления.КнигиНаРуках.Остатки(, Читатель = &Читатель) КАК КнигиНаРуках";
		ЗапросЛимит.УстановитьПараметр("Читатель", Читатель);
		РезЛимит = ЗапросЛимит.Выполнить().Выгрузить();

		ТекКол = 0;
		Если РезЛимит.Количество() > 0 И НЕ РезЛимит[0].КоличествоНаРуках = Null Тогда
			ТекКол = РезЛимит[0].КоличествоНаРуках;
		КонецЕсли;

		Если ТекКол + Книги.Количество() > МаксКниг Тогда
			Сообщение = Новый СообщениеПользователю;
			Сообщение.Текст = СтрШаблон("Читатель превысит лимит (%1 кн.). На руках: %2, добавляется: %3.",
				МаксКниг, ТекКол, Книги.Количество());
			Сообщение.Сообщить();
			Отказ = Истина;
			Возврат;
		КонецЕсли;

	КонецЕсли;

	// Движения по регистру накопления КнигиНаРуках
	Движения.КнигиНаРуках.Записывать = Истина;

	Для Каждого Строка Из Книги Цикл

		Движение = Движения.КнигиНаРуках.Добавить();
		Движение.ВидДвижения   = ВидДвиженияНакопления.Приход;
		Движение.Период        = Дата;
		Движение.Читатель      = Читатель;
		Движение.Книга         = Строка.Книга;
		Движение.КодЭкземпляра = Строка.КодЭкземпляра;
		Движение.Количество    = 1;
		Движение.ДатаВозврата  = ДатаВозврата;

	КонецЦикла;

	// Прямая запись в регистр сведений ИсторияВыдач
	Для Каждого Строка Из Книги Цикл

		НаборЗаписей = РегистрыСведений.ИсторияВыдач.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Читатель.Установить(Читатель);
		НаборЗаписей.Отбор.КодЭкземпляра.Установить(Строка.КодЭкземпляра);
		НаборЗаписей.Отбор.ДатаВыдачи.Установить(Дата);

		ЗаписьИст = НаборЗаписей.Добавить();
		ЗаписьИст.Читатель      = Читатель;
		ЗаписьИст.КодЭкземпляра = Строка.КодЭкземпляра;
		ЗаписьИст.ДатаВыдачи    = Дата;
		ЗаписьИст.Книга         = Строка.Книга;
		ЗаписьИст.ДатаВозврата  = ДатаВозврата;

		НаборЗаписей.Записать();

	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)

	Движения.КнигиНаРуках.Записывать = Истина;

КонецПроцедуры

#КонецОбласти
