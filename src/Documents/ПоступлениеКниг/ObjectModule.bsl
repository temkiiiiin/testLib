// @strict-types

#Область ОбработчикиСобытий

Процедура ОбработкаПроведения(Отказ, РежимПроведения)

	// Движения по регистру накопления ФондКниг
	Движения.ФондКниг.Записывать = Истина;

	Для Каждого Строка Из Книги Цикл

		Движение = Движения.ФондКниг.Добавить();
		Движение.ВидДвижения   = ВидДвиженияНакопления.Приход;
		Движение.Период        = Дата;
		Движение.Книга         = Строка.Книга;
		Движение.МестоХранения = МестоХранения;
		Движение.Состояние     = Строка.Состояние;
		Движение.Количество    = Строка.Количество;

	КонецЦикла;

	// Прямая запись в регистр сведений ЭкземплярыКниг
	Для Каждого Строка Из Книги Цикл

		Если НЕ ПустаяСтрока(Строка.КодЭкземпляра) Тогда

			НаборЗаписей = РегистрыСведений.ЭкземплярыКниг.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.КодЭкземпляра.Установить(Строка.КодЭкземпляра);
			НаборЗаписей.Прочитать();

			ЗаписьЭкз = НаборЗаписей.Добавить();
			ЗаписьЭкз.КодЭкземпляра = Строка.КодЭкземпляра;
			ЗаписьЭкз.Книга          = Строка.Книга;
			ЗаписьЭкз.МестоХранения  = МестоХранения;
			ЗаписьЭкз.Состояние      = Строка.Состояние;
			ЗаписьЭкз.Статус         = "Свободна";

			НаборЗаписей.Записать();

		КонецЕсли;

	КонецЦикла;

КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)

	Движения.ФондКниг.Записывать = Истина;

КонецПроцедуры

#КонецОбласти
